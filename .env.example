# ─── Database ────────────────────────────────────────────────────────────────
# Development (Docker on 5433):
DATABASE_URL=postgresql://beitdin_user:strongpassword@localhost:5433/beitdin_db
# Production (setup.sh generates a random password and sets this automatically):
# DATABASE_URL=postgresql://beitdin_user:GENERATED@localhost:5433/beitdin_db

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-this-to-a-long-random-string-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_REDIRECT_URI_DAYAN=http://localhost:8000/auth/dayan/google/callback
GOOGLE_REDIRECT_URI_LAWYER=http://localhost:8000/auth/lawyer/google/callback
# Production values (set automatically by setup.sh):
# GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/google/callback
# GOOGLE_REDIRECT_URI_DAYAN=https://yourdomain.com/auth/dayan/google/callback
# GOOGLE_REDIRECT_URI_LAWYER=https://yourdomain.com/auth/lawyer/google/callback

# ─── Google Drive ─────────────────────────────────────────────────────────────
# Service Account JSON from Google Cloud Console
GOOGLE_DRIVE_FOLDER_ID=your-shared-drive-folder-id
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ─── Hyp Payment ──────────────────────────────────────────────────────────────
# https://www.hyp.co.il/developers
HYP_API_URL=https://api.hyp.co.il
HYP_MERCHANT_ID=your-hyp-merchant-id
HYP_API_KEY=your-hyp-api-key
HYP_SECRET_KEY=your-hyp-secret-key

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Gmail: create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=DinLink

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development          # "production" in prod (hides /docs, enables Secure cookies)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
# Production:
# APP_ENV=production
# FRONTEND_URL=https://yourdomain.com
# BACKEND_URL=https://yourdomain.com
