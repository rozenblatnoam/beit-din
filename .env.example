# ─── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://beitdin_user:strongpassword@db:5432/beitdin_db

# ─── JWT ───────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Google OAuth ──────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ─── Google Drive ──────────────────────────────────────
GOOGLE_DRIVE_FOLDER_ID=your-shared-drive-folder-id
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ─── Hyp Payment ───────────────────────────────────────
HYP_API_URL=https://api.hyp.co.il
HYP_MERCHANT_ID=your-hyp-merchant-id
HYP_API_KEY=your-hyp-api-key
HYP_SECRET_KEY=your-hyp-secret-key

# ─── Email (SMTP) ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@karmeimishpat.co.il
EMAIL_FROM_NAME=כרמי המשפט

# ─── App ───────────────────────────────────────────────
APP_ENV=development
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
